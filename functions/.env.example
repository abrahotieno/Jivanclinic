# Local emulator only — copy to .env (gitignored). Production: Firebase Console params + Secret Manager.
# Do not put real secrets in git.

MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=

# Client secret is a Firebase secret in prod: firebase functions:secrets:set MS_GRAPH_CLIENT_SECRET
# For emulator, some setups use .env with dotenv — optional.
# MS_GRAPH_CLIENT_SECRET=

# Graph site id (hostname + path after decoding). NOT the full https URL.
MS_GRAPH_SITE_ID=jivanwellness.sharepoint.com:/sites/JivanWellness

# Either set the list GUID, or leave blank and use display name:
# MS_GRAPH_LIST_ID=

MS_GRAPH_LIST_DISPLAY_NAME=Website Interest Form

# WAITLIST_PRIMARY=auto
# WAITLIST_MIRROR_TO_FIRESTORE=false
